# ==========================================================
# GuildCMS .htaccess
# Optimized 2026
# ==========================================================

# ----------------------------------------------------------
# Security Headers
# ----------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-UA-Compatible "IE=Edge"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header unset ETag
</IfModule>

FileETag None

# ----------------------------------------------------------
# Protect .htaccess
# ----------------------------------------------------------
<Files ".htaccess">
    Require all denied
</Files>

# ----------------------------------------------------------
# PHP Settings
# ----------------------------------------------------------
# NOTE:
# php5_module kept only for older Apache handlers
# Modern PHP-FPM ignores this section
# ----------------------------------------------------------
<IfModule php5_module>
    php_flag display_errors Off
    php_value max_execution_time 1500
    php_value max_file_uploads 500
    php_value max_input_time 900
    php_value max_input_vars 3000
    php_value memory_limit 256M
    php_value session.gc_maxlifetime 14400
</IfModule>

# ----------------------------------------------------------
# MIME Types
# ----------------------------------------------------------
AddType application/javascript js

# Images
AddType image/webp webp
AddType image/svg+xml svg svgz
AddEncoding gzip svgz

# Icons
AddType image/x-icon ico

# Audio
AddType audio/ogg oga ogg
AddType audio/mp4 m4a

# Video
AddType video/ogg ogv
AddType video/mp4 mp4 m4v
AddType video/webm webm

# Fonts
AddType font/ttf ttf ttc
AddType font/otf otf
AddType font/woff woff
AddType font/woff2 woff2

# Misc
AddType text/cache-manifest appcache manifest
AddType text/x-component htc
AddType text/x-vcard vcf

# ----------------------------------------------------------
# Compression
# ----------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ----------------------------------------------------------
# Browser Cache
# ----------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    # Dynamic content
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"

    # CSS / JS
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Images
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresDefault "access plus 1 month"
</IfModule>

# ----------------------------------------------------------
# Cache Headers
# ----------------------------------------------------------
<IfModule mod_headers.c>
    # Static assets
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|css|js|woff|woff2|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # PHP generated pages
    <FilesMatch "\.(php|html|htm)$">
        Header set Cache-Control "private, no-cache, must-revalidate"
    </FilesMatch>

    # CDN / font support
    <FilesMatch "\.(ttf|otf|woff|woff2|svg)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ----------------------------------------------------------
# UTF-8
# ----------------------------------------------------------
AddDefaultCharset utf-8
AddCharset utf-8 \
.html \
.css \
.js \
.xml \
.json \
.rss \
.atom

# ----------------------------------------------------------
# Disable MultiViews
# Required for clean URLs
# ----------------------------------------------------------
Options -MultiViews

# ----------------------------------------------------------
# Rewrite Section
# ----------------------------------------------------------
RewriteEngine On

RewriteBase /

RewriteCond %{HTTP_USER_AGENT} ^Bullseye.* [OR]
RewriteCond %{HTTP_USER_AGENT} ^fastlwspider* [OR]
RewriteCond %{HTTP_USER_AGENT} ^EmailSiphon [OR]
RewriteCond %{HTTP_USER_AGENT} ^EmailCollector [OR]
RewriteCond %{HTTP_USER_AGENT} ^EmailWolf [OR]
RewriteCond %{HTTP_USER_AGENT} ^ExtractorPro [OR]
RewriteCond %{HTTP_USER_AGENT} ^GetWebPage.* [OR]
RewriteCond %{HTTP_USER_AGENT} ^lwp-tribial.* [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla.*NEWT [OR]
RewriteCond %{HTTP_USER_AGENT} ^Crescent [OR]
RewriteCond %{HTTP_USER_AGENT} ^CherryPicker [OR]
RewriteCond %{HTTP_USER_AGENT} ^[Ww]eb[Bb]andit [OR]
RewriteCond %{HTTP_USER_AGENT} ^WebEMailExtrac.* [OR]
RewriteCond %{HTTP_USER_AGENT} ^NICErsPRO [OR]
RewriteCond %{HTTP_USER_AGENT} ^SurfWalker [OR]
RewriteCond %{HTTP_USER_AGENT} ^Telesoft [OR]
RewriteCond %{HTTP_USER_AGENT} ^Zeus.*Webster [OR]
RewriteCond %{HTTP_USER_AGENT} ^Microsoft.URL [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/3.Mozilla/2.01 [OR]
RewriteCond %{HTTP_USER_AGENT} ^EmailCollector
#RewriteRule ^.*$ - [F]
#RewriteRule "(^|/)\." - [F]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)\.(\d+)\.(js|css|png|jpg|gif)$ $1.$3 [L]
RewriteCond %{QUERY_STRING} ^(%2d|-)[^=]+$ [NC]
#RewriteRule ^(.*) $1? [L]
RewriteCond %{QUERY_STRING} ^[^=]*$
RewriteCond %{QUERY_STRING} %2d|\- [NC]
#RewriteRule .? - [F,L]
RewriteCond %{REQUEST_URI} !^/\.well-known
#RewriteRule "(^|/)\." - [F]

## Error Document Handling
# Client Request Errors
ErrorDocument 400 /index.php?page=400
ErrorDocument 401 /index.php?page=401
ErrorDocument 402 /index.php?page=402
ErrorDocument 403 /index.php?page=403
ErrorDocument 404 /index.php?page=404
ErrorDocument 405 /index.php?page=405
ErrorDocument 408 /index.php?page=408
ErrorDocument 410 /index.php?page=410
ErrorDocument 429 /index.php?page=429
ErrorDocument 500 /index.php?page=500
ErrorDocument 503 /index.php?page=503

AddType video/divx divx
AddHandler php-source .phps
AddHandler x-httpd-php-source .phps
AddType application/x-httpd-php-source .phps

<Files "includes/config.inc.php">
Order Allow,Deny
Deny from All
</Files>

# Friendly article URLs
# Place these after RewriteEngine On and before the generic site page fallback.

# Root article pages:
# /articles
# /articles/article-slug
# /articles/category/category-name
# /articles/category/category-name/article-slug
RewriteRule ^articles/?$ index.php?page=articles&category=news [L,QSA]
RewriteRule ^articles/category/([a-z0-9_-]+)/?$ index.php?page=articles&category=$1 [L,QSA]
RewriteRule ^articles/category/([a-z0-9_-]+)/([a-z0-9_-]+)/?$ index.php?page=articles&category=$1&slug=$2 [L,QSA]
RewriteRule ^articles/([a-z0-9_-]+)/?$ index.php?page=articles&category=news&slug=$1 [L,QSA]

# Site article pages:
# /wow/articles
# /wow/articles/article-slug
# /wow/articles/category/introduction
# /wow/articles/category/introduction/article-slug
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/articles/?$ index.php?site=$1&page=articles&category=news [L,QSA]
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/articles/category/([a-z0-9_-]+)/?$ index.php?site=$1&page=articles&category=$2 [L,QSA]
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/articles/category/([a-z0-9_-]+)/([a-z0-9_-]+)/?$ index.php?site=$1&page=articles&category=$2&slug=$3 [L,QSA]
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/articles/([a-z0-9_-]+)/?$ index.php?site=$1&page=articles&category=news&slug=$2 [L,QSA]


# Root shared pages
RewriteRule ^(about|contact|coc|charter|join|history)/?$ index.php?page=$1 [L,QSA]
RewriteRule ^(about|contact|coc|charter|join|history)\.php$ index.php?page=$1 [L,QSA]

# Site home pages
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/?$ index.php?site=$1&page=index [L,QSA]

# Site article/news wrappers
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/articles/?$ index.php?site=$1&page=articles [L,QSA]
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/articles\.php$ index.php?site=$1&page=articles [L,QSA]

# Site intro/introduction wrappers
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/(intro|introduction)/?$ index.php?site=$1&page=intro [L,QSA]
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/(intro|introduction)\.php$ index.php?site=$1&page=intro [L,QSA]

# Generic site page fallback
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/([a-z0-9_-]+)/?$ index.php?site=$1&page=$2 [L,QSA]
RewriteRule ^(ac|ao|cod|coh|eve|fo76|tsw|wow)/([a-z0-9_-]+)\.php$ index.php?site=$1&page=$2 [L,QSA]

# Rewrite for Main Site Pages
RewriteRule ^$ index.php?page=home [L,QSA]

RewriteCond %{QUERY_STRING} ^$
RewriteRule ^index\.php$ index.php?page=home [L,QSA]

RewriteRule ^links\.php$ index.php?page=links [L,QSA]
RewriteRule ^forums\.php$ index.php?page=forums [L,QSA]
RewriteRule ^images\.php$ index.php?page=home&a=images [L,QSA]
RewriteRule ^members\.php$ index.php?page=home&a=members [L,QSA]
RewriteRule ^member/(.+)\.php$ index.php?page=home&a=member&n=$1 [L,QSA]

RewriteRule ^coc\.php$ index.php?page=coc [L,QSA]
RewriteRule ^charter\.php$ index.php?page=charter [L,QSA]
RewriteRule ^recruit\.php$ index.php?page=recruit [L,QSA]
RewriteRule ^join\.php$ index.php?page=join [L,QSA]
RewriteRule ^history\.php$ index.php?page=history [L,QSA]
RewriteRule ^about\.php$ index.php?page=about [L,QSA]
RewriteRule ^privacy\.php$ index.php?page=privacy [L,QSA]
RewriteRule ^tou\.php$ index.php?page=terms [L,QSA]
RewriteRule ^terms\.php$ index.php?page=terms [L,QSA]
RewriteRule ^trade\.php$ index.php?page=marks [L,QSA]
RewriteRule ^sitemap\.php$ index.php?page=sitemap [L,QSA]
RewriteRule ^contact\.php$ index.php?page=contact [L,QSA]
RewriteRule ^rss\.php$ index.php?page=print_rss [L,QSA]
RewriteRule ^gallery\.php$ index.php?page=images [L,QSA]
RewriteRule ^videos\.php$ index.php?page=videos [L,QSA]

# Main Site Gallery Pages
RewriteRule ^images/([0-9]+)\.php$ index.php?page=home&a=images&pageno=$1 [L,QSA]

# Rewrite for Default Pages
RewriteRule ^default/?$ index.php?site=ac&page=index [L,QSA]
RewriteRule ^default/index\.php$ index.php?site=ac&page=index [L,QSA]

RewriteRule ^default/rhinos\.php$ index.php?site=ac&page=rhinos [L,QSA]
RewriteRule ^default/links\.php$ index.php?site=ac&page=links [L,QSA]
RewriteRule ^default/forums\.php$ index.php?site=ac&page=forums [L,QSA]
RewriteRule ^default/diplomacy\.php$ index.php?site=ac&page=diplomacy [L,QSA]
RewriteRule ^default/kos\.php$ index.php?site=ac&page=kos [L,QSA]
RewriteRule ^default/coc\.php$ index.php?site=ac&page=coc [L,QSA]
RewriteRule ^default/charter\.php$ index.php?site=ac&page=charter [L,QSA]
RewriteRule ^default/recruit\.php$ index.php?site=ac&page=join [L,QSA]
RewriteRule ^default/history\.php$ index.php?site=ac&page=history [L,QSA]
RewriteRule ^default/map\.php$ index.php?site=ac&page=map [L,QSA]
RewriteRule ^default/rhino\.php$ index.php?site=ac&page=rhino [L,QSA]
RewriteRule ^default/spells\.php$ index.php?site=ac&page=spells [L,QSA]

RewriteRule ^default/gallery\.php$ index.php?site=ac&page=gallery [L,QSA]
RewriteRule ^default/gallery/?$ index.php?site=ac&page=gallery&pageno=1 [L,QSA]
RewriteRule ^default/gallery/([0-9]+)$ index.php?site=ac&page=gallery&pageno=$1 [L,QSA]

RewriteRule ^default/videos\.php$ index.php?site=ac&page=videos [L,QSA]
RewriteRule ^default/videos/?$ index.php?site=ac&page=videos&pageno=1 [L,QSA]
RewriteRule ^default/videos/([0-9]+)$ index.php?site=ac&page=videos&pageno=$1 [L,QSA]

RewriteRule ^default/tree\.php$ index.php?site=ac&page=tree [L,QSA]
RewriteRule ^default/tree/?$ index.php?site=ac&page=tree [L,QSA]
RewriteRule ^default/tree/index\.php$ index.php?site=ac&page=tree [L,QSA]

